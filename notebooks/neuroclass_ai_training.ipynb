   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "# ─── CREDENTIALS ──────────────────────────────────────────────────────────────\n",
    "# Paste your values below OR use Google Colab Secrets (recommended)\n",
    "# In Colab: Runtime > Manage secrets > Add SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, GEMINI_API_KEY\n",
    "\n",
    "try:\n",
    "    from google.colab import userdata\n",
    "    SUPABASE_URL = userdata.get('SUPABASE_URL')\n",
    "    SUPABASE_SERVICE_ROLE_KEY = userdata.get('SUPABASE_SERVICE_ROLE_KEY')\n",
    "    GEMINI_API_KEY = userdata.get('GEMINI_API_KEY')\n",
    "except Exception:\n",
    "    SUPABASE_URL = os.getenv('SUPABASE_URL', 'https://tvizwaysproajwebglwv.supabase.co')\n",
    "    SUPABASE_SERVICE_ROLE_KEY = os.getenv('SUPABASE_SERVICE_ROLE_KEY', '')\n",
    "    GEMINI_API_KEY = os.getenv('GEMINI_API_KEY', '')\n",
    "\n",
    "os.environ['GOOGLE_API_KEY'] = GEMINI_API_KEY\n",
    "print('Credentials loaded.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from supabase import create_client\n",
    "import pandas as pd\n",
    "\n",
    "# Use service_role key to bypass RLS and access all data for training\n",
    "sb = create_client(SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY)\n",
    "\n",
    "# ─── Fetch student queries ────────────────────────────────────────────────────\n",
    "resp = sb.table('student_queries').select('*').order('created_at').execute()\n",
    "queries_df = pd.DataFrame(resp.data)\n",
    "print(f'Loaded {len(queries_df)} student queries.')\n",
    "queries_df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Fetch course contents (chunked text from uploaded files) ─────────────────\n",
    "resp = sb.table('course_contents').select('id, course_id, content_chunk').execute()\n",
    "contents_df = pd.DataFrame(resp.data)\n",
    "print(f'Loaded {len(contents_df)} course content chunks.')\n",
    "\n",
    "# ─── Fetch gold samples for evaluator training ────────────────────────────────\n",
    "resp = sb.table('ai_gold_samples').select('*').execute()\n",
    "gold_df = pd.DataFrame(resp.data)\n",
    "print(f'Loaded {len(gold_df)} gold samples for evaluator training.')"\n",
    ""
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── LangChain: Build a RAG chain from course contents ───────────────────────\n",
    "from langchain_google_genai import ChatGoogleGenerativeAI, GoogleGenerativeAIEmbeddings\n",
    "from langchain_core.documents import Document\n",
    "from langchain_community.vectorstores import SKLearnVectorStore\n",
    "\n",
    "docs = [\n",
    "    Document(page_content=row['content_chunk'], metadata={'course_id': row['course_id']})\n",
    "    for _, row in contents_df.iterrows()\n",
    "]\n",
    "\n",
    "embeddings = GoogleGenerativeAIEmbeddings(model='models/embedding-001')\n",
    "\n",
    "if docs:\n",
    "    vectorstore = SKLearnVectorStore.from_documents(docs, embeddings)\n",
    "    retriever = vectorstore.as_retriever(search_kwargs={'k': 4})\n",
    "    print('RAG vectorstore built from course contents.')\n",
    "else:\n",
    "    retriever = None\n",
    "    print('No course content yet. Upload course materials via the NeuroClass app first.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── LangGraph: Conversational AI Tutor Agent ─────────────────────────────────\n",
    "from langgraph.graph import StateGraph, END\n",
    "from langchain_core.messages import HumanMessage, AIMessage\n",
    "from langchain_google_genai import ChatGoogleGenerativeAI\n",
    "from typing import TypedDict, List, Any\n",
    "\n",
    "llm = ChatGoogleGenerativeAI(model='gemini-2.5-flash', temperature=0.3)\n",
    "\n",
    "class TutorState(TypedDict):\n",
    "    messages: List[Any]\n",
    "    course_context: str\n",
    "\n",
    "def retrieve_context(state: TutorState) -> TutorState:\n",
    "    if retriever is None:\n",
    "        return {**state, 'course_context': ''}\n",
    "    last_human = next((m.content for m in reversed(state['messages']) if isinstance(m, HumanMessage)), '')\n",
    "    docs = retriever.invoke(last_human)\n",
    "    context = '\\n\\n'.join(d.page_content for d in docs)\n",
    "    return {**state, 'course_context': context}\n",
    "\n",
    "def answer(state: TutorState) -> TutorState:\n",
    "    system = f\"\"\"You are a helpful AI tutor for NeuroClass.\n",
    "Guide the student with Socratic questioning rather than direct answers.\n",
    "\nRelevant course material:\n{state['course_context']}\"\"\"\n",
    "    messages = [HumanMessage(content=system)] + state['messages']\n",
    "    reply = llm.invoke(messages)\n",
    "    return {**state, 'messages': state['messages'] + [reply]}\n",
    "\n",
    "graph = StateGraph(TutorState)\n",
    "graph.add_node('retrieve', retrieve_context)\n",
    "graph.add_node('answer', answer)\n",
    "graph.set_entry_point('retrieve')\n",
    "graph.add_edge('retrieve', 'answer')\n",
    "graph.add_edge('answer', END)\n",
    "tutor_agent = graph.compile()\n",
    "print('LangGraph tutor agent compiled.')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ─── Test the agent ───────────────────────────────────────────────────────────\n",
    "result = tutor_agent.invoke({\n",
    "    'messages': [HumanMessage(content='What is gradient descent?')],\n",
    "    'course_context': ''\n",
    "})\n",
    "print('Agent reply:', result['messages'][-1].content)"
   ]
  },
  {
