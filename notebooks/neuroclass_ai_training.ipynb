   "source": [
    "# ─── Save fine-tuning dataset from student queries ────────────────────────────\n",
    "if not queries_df.empty and 'query_text' in queries_df.columns and 'ai_reply' in queries_df.columns:\n",
    "    dataset = queries_df[['query_text', 'ai_reply', 'course_id', 'created_at']].dropna(subset=['query_text', 'ai_reply'])\n",
    "    dataset.columns = ['input', 'output', 'course_id', 'timestamp']\n",
    "    dataset.to_csv('neuroclass_training_dataset.csv', index=False)\n",
    "    print(f'Training dataset saved: {len(dataset)} rows -> neuroclass_training_dataset.csv')\n",
    "else:\n",
    "    print('No data to save yet.')"
   ]
  }
