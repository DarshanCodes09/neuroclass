# ────────────────────────────────────────────────────────────────────────────
# NeuroClass — root .env.example
# Copy this to .env (never commit .env)
# ────────────────────────────────────────────────────────────────────────────

# Supabase Project (Settings → API)
SUPABASE_URL=https://tvizwaysproajwebglwv.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Service Role Key — SERVER / PYTHON ONLY.  NEVER expose in the client/browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI Provider (gemini | anthropic)
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Optional: Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Server
PORT=8000
NODE_ENV=development
