# =============================================
# NeuroClass — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================

# =============================================
# Supabase
# Get from: https://supabase.com/dashboard/project/<your-project>/settings/api
# Project URL: https://tvizwaysproajwebglwv.supabase.co
# =============================================
SUPABASE_URL=https://tvizwaysproajwebglwv.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# service_role key — SERVER ONLY, never expose in client or frontend
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================
# AI Provider
# Set AI_PROVIDER=gemini to use Google Gemini (default)
# Set AI_PROVIDER=anthropic to use Claude
# Set AI_PROVIDER=openai to use OpenAI GPT
# =============================================
AI_PROVIDER=gemini

# =============================================
# Google Gemini
# Get your key from: https://aistudio.google.com/app/apikey
# =============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# =============================================
# Anthropic Claude
# Get your key from: https://console.anthropic.com/
# =============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================
# OpenAI (used by Python/Colab AI training notebook)
# Get from: https://platform.openai.com/api-keys
# =============================================
OPENAI_API_KEY=your_openai_api_key_here

# =============================================
# Server
# =============================================
PORT=8000
NODE_ENV=development
