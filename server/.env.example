# NeuroClass Server — Environment Variables
# Copy this to server/.env and fill in your values

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# SERVICE ROLE KEY — server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── AI Providers ──────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key
GEMINI_API_KEY=your_gemini_key

# ── App ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Colab / Python AI Training ────────────────────────────────────
# In Google Colab, add these via: Secrets (key icon) panel
# Key name          Value
# SUPABASE_URL      https://YOUR_PROJECT_REF.supabase.co
# SUPABASE_SERVICE_KEY  your_service_role_key_here
# OPENAI_API_KEY    your_openai_key
