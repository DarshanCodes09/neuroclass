# =============================================
# AI Provider
# Set AI_PROVIDER=anthropic to use Claude
# Set AI_PROVIDER=gemini to use Gemini
# If omitted, the server auto-detects based on available keys
# =============================================
AI_PROVIDER=gemini

# =============================================
# Anthropic Claude
# Get your key from: https://console.anthropic.com/
# =============================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# =============================================
# Google Gemini
# Get your key from: https://aistudio.google.com/app/apikey
# =============================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# =============================================
# Server Port (leave as 8000 for local dev)
# =============================================
PORT=8000

# =============================================
# Supabase (replaces MySQL)
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api
# =============================================
SUPABASE_URL=https://tvizwaysproajwebglwv.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# service_role key — keep secret, never expose in client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
